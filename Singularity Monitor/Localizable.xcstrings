      "localizations": {
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Constante verdubbelingstijd. Het rechte-lijnverhaal op een log-grafiek."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Konstante Verdopplungszeit. Die Geradlinige Erzählung auf einem Log-Diagramm."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Temps de doublement constant. L'histoire en ligne droite sur un graphique logarithmique."
